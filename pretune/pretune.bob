  <widget type="action_button" version="3.0.0">
    <name>btnApplyStates</name>
    <actions>
      <action type="execute">
        <description>Bring selected PS to desired state</description>
        <script file="EmbeddedPy">
          <text><![CDATA[# Embedded python script
from org.csstudio.display.builder.runtime.script import PVUtil
from org.phoebus.pv import PVPool
from java.lang import Exception

TAG = "loc://apply:unimag:"
SUFFIX = ":STATE_SP"

for pvr in PVPool.getPVReferences():
    pvname = pvr.getEntry().getName()
    if pvname.startswith(TAG) and pvname.endswith(SUFFIX):
        root = pvname[len(TAG):-len(SUFFIX)]
        try:
            enabled = PVUtil.createPV(TAG+root+":enabled", 10)
            if PVUtil.getLong(enabled) == 0:
                print("SKIP "+root+" (deselected)")
                continue
            local = PVUtil.createPV(pvname, 10)
            value = PVUtil.getString(local)
            remote = PVUtil.createPV(root+":STATE_SP", 100)
            remote.write(value)
            print("APPLY "+root+":STATE_SP = "+str(value))
        except Exception as e:
            print("## Error applying state for "+root+": "+str(e))
]]></text>
        </script>
      </action>
    </actions>
    <text>Set Selected States</text>
    <x>925</x>
    <y>80</y>
    <width>115</width>
    <tooltip>Push every selected (checked) power supply's desired state to hardware</tooltip>
    <border_alarm_sensitive>false</border_alarm_sensitive>
