  <widget type="action_button" version="3.0.0">
    <name>LoadSetting</name>
    <actions>
      <action type="execute">
        <description>StepDown</description>
        <script file="EmbeddedPy">
          <text><![CDATA[# Embedded python script
from org.csstudio.display.builder.runtime.script import PVUtil, ScriptUtil
from org.phoebus.pv import PVPool
from java.lang import Exception

TAG = "loc://apply:unimag:"
SUFFIX = ":CURRENT_PREV_SP"

for pvr in PVPool.getPVReferences():
    pvname = pvr.getEntry().getName()
    if pvname.startswith(TAG) and pvname.endswith(SUFFIX):
        root = pvname[len(TAG):-len(SUFFIX)]
        try:
            enabled = PVUtil.createPV(TAG+root+":enabled", 10)
            if PVUtil.getLong(enabled) == 0:
                print("SKIP "+root+" (deselected)")
                continue
            local = PVUtil.createPV(pvname, 10)
            value = PVUtil.getDouble(local)
            remote = PVUtil.createPV(root+":CURRENT_SP", 100)
            remote.write(value)
            print("APPLY "+root+":CURRENT_SP = "+str(value))

            state_local = PVUtil.createPV(TAG+root+":STATE_SP", 10)
            state_value = PVUtil.getString(state_local)
            state_remote = PVUtil.createPV(root+":STATE_SP", 100)
            state_remote.write(state_value)
            print("APPLY "+root+":STATE_SP = "+str(state_value))
        except Exception as e:
            print("## Error applying "+root+": "+str(e))

pv = ScriptUtil.getPrimaryPV(widget)
pvInt0 = PVUtil.getLong(pv) - 1
pv.write(pvInt0)
]]></text>
        </script>
      </action>
    </actions>
    <pv_name>loc://counter_$(DID)</pv_name>
    <text>&lt;</text>
    <x>10</x>
    <y>80</y>
    <rules>
      <rule name="visibility" prop_id="enabled" out_exp="false">
        <exp bool_exp="pvInt0&gt;0">
          <value>true</value>
        </exp>
        <exp bool_exp="pvInt0==0">
          <value>false</value>
        </exp>
        <pv_name>loc://counter_$(DID)</pv_name>
      </rule>
    </rules>
    <tooltip>$(actions)</tooltip>
    <border_alarm_sensitive>false</border_alarm_sensitive>
    <enabled>false</enabled>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>dump</name>
    <actions>
      <action type="execute">
        <description>Stepup</description>
        <script file="EmbeddedPy">
          <text><![CDATA[# Embedded python script
from org.csstudio.display.builder.runtime.script import PVUtil, ScriptUtil
from org.phoebus.pv import PVPool
from java.lang import Exception

TAG = "loc://apply:unimag:"
SUFFIX = ":CURRENT_NEXT_SP"

for pvr in PVPool.getPVReferences():
    pvname = pvr.getEntry().getName()
    if pvname.startswith(TAG) and pvname.endswith(SUFFIX):
        root = pvname[len(TAG):-len(SUFFIX)]
        try:
            enabled = PVUtil.createPV(TAG+root+":enabled", 10)
            if PVUtil.getLong(enabled) == 0:
                print("SKIP "+root+" (deselected)")
                continue
            local = PVUtil.createPV(pvname, 10)
            value = PVUtil.getDouble(local)
            remote = PVUtil.createPV(root+":CURRENT_SP", 100)
            remote.write(value)
            print("APPLY "+root+":CURRENT_SP = "+str(value))

            state_local = PVUtil.createPV(TAG+root+":STATE_SP", 10)
            state_value = PVUtil.getString(state_local)
            state_remote = PVUtil.createPV(root+":STATE_SP", 100)
            state_remote.write(state_value)
            print("APPLY "+root+":STATE_SP = "+str(state_value))
        except Exception as e:
            print("## Error applying "+root+": "+str(e))

pv = ScriptUtil.getPrimaryPV(widget)
pvInt0 = PVUtil.getLong(pv) + 1
pv.write(pvInt0)
]]></text>
        </script>
      </action>
    </actions>
    <pv_name>loc://counter_$(DID)</pv_name>
    <text>&gt;</text>
    <x>270</x>
    <y>80</y>
    <rules>
      <rule name="visibility" prop_id="enabled" out_exp="false">
        <exp bool_exp="pvInt0&lt;pvInt1">
          <value>true</value>
        </exp>
        <exp bool_exp="pvInt0==pvInt1">
          <value>false</value>
        </exp>
        <pv_name>loc://counter_$(DID)</pv_name>
        <pv_name>loc://nsteps_$(DID)</pv_name>
      </rule>
    </rules>
    <tooltip>$(actions)</tooltip>
    <border_alarm_sensitive>false</border_alarm_sensitive>
    <enabled>false</enabled>
  </widget>
