  <widget type="action_button" version="3.0.0">
    <name>MainPanelButton2</name>
    <actions>
      <action type="open_display">
        <description>Open Main Control Panel</description>
        <file>danfysik_main.bob</file>
        <macros>
          <DEVICE>$(DEVICE)</DEVICE>
        </macros>
        <target>tab</target>
      </action>
    </actions>
    <text>Main Panel</text>
    <x>20</x>
    <y>640</y>
    <width>120</width>
    <tooltip>$(actions)</tooltip>
