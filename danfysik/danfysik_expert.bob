<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>Danfysik Expert Panel</name>
  <macros>
    <DEVICE>BTF:MAG:DANFYSIK:QUATM002</DEVICE>
  </macros>
  <width>1000</width>
  <height>1010</height>
  <background_color>
    <color name="Display_Background" red="255" green="255" blue="255">
    </color>
  </background_color>
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>Danfysik SYS8X00 - Expert/Debug Panel</text>
    <x>20</x>
    <y>10</y>
    <width>400</width>
    <height>30</height>
    <font>
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="22.0">
      </font>
    </font>
    <foreground_color>
      <color name="STOP" red="255" green="0" blue="0">
      </color>
    </foreground_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Warning</name>
    <text>⚠️ EXPERT MODE - Use with caution! Direct hardware control.</text>
    <x>20</x>
    <y>45</y>
    <width>600</width>
    <font>
      <font name="Default Bold" family="Liberation Sans" style="BOLD" size="14.0">
      </font>
    </font>
    <foreground_color>
      <color name="MAJOR" red="255" green="0" blue="0">
      </color>
    </foreground_color>
  </widget>
  <widget type="rectangle" version="2.0.0">
    <name>HardwareFrame</name>
    <x>20</x>
    <y>80</y>
    <width>960</width>
    <height>150</height>
    <line_color>
      <color name="MAJOR" red="255" green="0" blue="0">
      </color>
    </line_color>
    <background_color>
      <color name="Write_Background" red="128" green="255" blue="255">
      </color>
    </background_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>HardwareTitle</name>
    <text>Direct Hardware Control</text>
    <x>30</x>
    <y>90</y>
    <width>200</width>
    <font>
      <font name="Header 2" family="Liberation Sans" style="BOLD" size="18.0">
      </font>
    </font>
  </widget>
  <widget type="label" version="2.0.0">
    <name>DirectCurrentLabel</name>
    <text>Direct Current (DAC):</text>
    <x>30</x>
    <y>120</y>
    <width>130</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>DirectCurrent</name>
    <pv_name>$(P):$(R):I_SP</pv_name>
    <x>160</x>
    <y>120</y>
    <width>120</width>
    <precision>3</precision>
  </widget>
  <widget type="label" version="2.0.0">
    <name>DirectCurrentSPRB</name>
    <text>SP RB:</text>
    <x>290</x>
    <y>120</y>
    <width>40</width>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>DirectCurrentReadback</name>
    <pv_name>$(P):$(R):I_SP_RB</pv_name>
    <x>330</x>
    <y>120</y>
    <precision>3</precision>
  </widget>
  <widget type="label" version="2.0.0">
    <name>RawWaLabel</name>
    <text>Raw WA (DAC 0-999999):</text>
    <x>30</x>
    <y>180</y>
    <width>150</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>RawWaEntry</name>
    <pv_name>$(P):$(R):RAW_WA</pv_name>
    <x>185</x>
    <y>180</y>
  </widget>
  <widget type="label" version="2.0.0">
    <name>RawRaLabel2</name>
    <text>RA RB:</text>
    <x>300</x>
    <y>180</y>
    <width>50</width>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>RawRaReadback2</name>
    <pv_name>$(P):$(R):RAW_RA</pv_name>
    <x>355</x>
    <y>180</y>
    <width>80</width>
  </widget>
  <widget type="label" version="2.0.0">
    <name>AddressSetLabel</name>
    <text>Set Address:</text>
    <x>450</x>
    <y>120</y>
    <width>80</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>AddressSet</name>
    <pv_name>$(P):$(R):ADDR_SP</pv_name>
    <x>530</x>
    <y>120</y>
    <width>60</width>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>InitRemoteButton</name>
    <actions>
      <action type="write_pv">
        <description>Initialize Remote Control</description>
        <pv_name>$(P):$(R):INIT_REMOTE</pv_name>
        <value>1</value>
      </action>
    </actions>
    <text>INIT REMOTE</text>
    <x>620</x>
    <y>120</y>
    <height>25</height>
    <tooltip>$(actions)</tooltip>
  </widget>
  <widget type="action_button" version="3.0.0">
    <name>ErrorTextButton</name>
    <actions>
      <action type="write_pv">
        <description>Enable Text Error Messages</description>
        <pv_name>$(P):$(R):ERROR_TEXT</pv_name>
        <value>1</value>
      </action>
    </actions>
    <text>ERROR TEXT</text>
    <x>730</x>
    <y>120</y>
    <height>25</height>
    <tooltip>$(actions)</tooltip>
  </widget>
  <widget type="label" version="2.0.0">
    <name>AdvRampLabel</name>
    <text>Advanced Ramping:</text>
    <x>30</x>
    <y>150</y>
    <width>120</width>
  </widget>
  <widget type="label" version="2.0.0">
    <name>RampEndLabel2</name>
    <text>End:</text>
    <x>150</x>
    <y>150</y>
    <width>30</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>RampEndExpert</name>
    <pv_name>$(P):$(R):RAMP_END_SP</pv_name>
    <x>180</x>
    <y>150</y>
    <precision>3</precision>
  </widget>
  <widget type="label" version="2.0.0">
    <name>RampRateLabel2</name>
    <text>Rate:</text>
    <x>290</x>
    <y>150</y>
    <width>40</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>RampRateExpert</name>
    <pv_name>$(P):$(R):RAMP_RATE_SP</pv_name>
    <x>330</x>
    <y>150</y>
    <precision>2</precision>
  </widget>
  <widget type="label" version="2.0.0">
    <name>SeqTrigLabel</name>
    <text>Seq Trigger:</text>
    <x>450</x>
    <y>150</y>
    <width>80</width>
  </widget>
  <widget type="textentry" version="3.0.0">
    <name>SeqTrigger</name>
    <pv_name>$(P):$(R):SEQ_TRIGGER</pv_name>
    <x>530</x>
    <y>150</y>
    <width>60</width>
  </widget>
